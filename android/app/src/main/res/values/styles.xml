<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShapeAppearance.SmartLedger.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="TextAppearance.SmartLedger.Overline" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/sl_text_secondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.SmartLedger.OverlineMuted" parent="TextAppearance.SmartLedger.Overline">
        <item name="android:textColor">@color/sl_text_overline_muted</item>
    </style>

    <style name="TextAppearance.SmartLedger.HeroAmount" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textSize">48sp</item>
        <item name="android:textColor">@color/sl_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SmartLedger.TitleLarge" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/sl_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SmartLedger.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/sl_text_body</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>
