<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sl_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/sl_screen_padding_horizontal">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/sl_login_header_logo"
            android:layout_height="@dimen/sl_login_header_logo"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/sl_surface"
            app:cardCornerRadius="@dimen/sl_card_radius_small"
            app:cardElevation="2dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/app_name"
                android:padding="8dp"
                android:scaleType="centerCrop"
                android:src="@drawable/smartledger_logo" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            android:letterSpacing="0.2"
            android:text="SMARTLEDGER"
            android:textColor="@color/sl_text_brand_muted"
            android:textSize="10sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/sl_surface"
            app:cardCornerRadius="@dimen/sl_card_radius_large"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="40dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/sl_login_hero_icon"
                    android:layout_height="@dimen/sl_login_hero_icon"
                    android:layout_marginBottom="32dp"
                    android:rotation="3"
                    app:cardBackgroundColor="@color/sl_navy"
                    app:cardCornerRadius="@dimen/sl_card_radius_medium"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/app_name"
                        android:padding="16dp"
                        android:rotation="-3"
                        android:src="@drawable/ic_wallet_white" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smart Ledger"
                    android:textColor="@color/sl_text_primary"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="24dp"
                    android:text="Securely manage your expenses, split bills, and track your crypto portfolio in one place."
                    android:textAlignment="center"
                    android:textAppearance="@style/TextAppearance.SmartLedger.Body" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Email">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:text="demo@example.com" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:hint="Password"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:text="password123" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_google_login"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Log In"
                    android:textColor="@color/sl_text_on_dark"
                    app:backgroundTint="@color/sl_navy"
                    app:cornerRadius="@dimen/sl_card_radius_small"
                    app:icon="@drawable/ic_wallet_white"
                    app:iconGravity="textStart"
                    app:iconTint="@color/sl_text_on_dark" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_register"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="Create Demo Account" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="By continuing, you agree to our Terms &amp; Privacy Policy"
                    android:textAlignment="center"
                    android:textColor="@color/sl_text_body_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
